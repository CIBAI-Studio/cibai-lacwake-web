---
import ActivityLayout from '../../layouts/ActivityLayout.astro';
import { getCmsActivityContent, getSiteConfig } from '../../lib/cms';
import { waLink } from '../../config/actividades';

/**
 * Ruta dinámica 100% CMS-driven (CIBA-2526, sustituye a la whitelist
 * VALID_SLUGS): cualquier ficha `actividad_<slug>` creada en el admin gana
 * página aquí sin tocar código. Las páginas estáticas (kayak.astro, etc.)
 * ganan a esta ruta en Astro, así que sólo llegan slugs nuevos.
 *
 *  - Ficha inexistente en el CMS → 404 real (sin "próximamente" genérico).
 *  - Ficha existente sin cuerpo (`nonEmptyHtml`) → título + CTA de reserva.
 */
const { slug } = Astro.params;
const cms = slug && /^[a-z0-9-]+$/.test(slug) ? await getCmsActivityContent(slug) : null;
if (!cms) return Astro.rewrite('/404');

const siteConfig = await getSiteConfig();
const title = cms.title || slug!;
const reserveUrl = waLink(siteConfig.whatsappUrl, title);
---

<ActivityLayout
  title={title}
  description={cms.description}
  image={cms.image ?? '/assets/images/hero-fallback.jpg'}
  imageAlt={cms.imageAlt ?? `${title} en el pantano de Lacwake`}
  tag={cms.tag ?? 'Actividad'}
  duration={cms.duration}
  minAge={cms.minAge}
  price={cms.price}
  included={cms.included ?? []}
>
  {cms.body ? (
    <div class="cms-body" set:html={cms.body} />
  ) : (
    <div class="no-body">
      <h2>{title} en Lacwake</h2>
      <p>
        Reserva tu plaza de <strong>{title}</strong> en el pantano de la Baells:
        escríbenos por WhatsApp y te confirmamos al momento.
      </p>
      <a href={reserveUrl} class="no-body-cta" target="_blank" rel="noopener noreferrer">
        Reservar {title}
      </a>
      <p class="no-body-back">
        <a href="/#actividades">← Ver todas las actividades</a>
      </p>
    </div>
  )}
</ActivityLayout>

<style>
  .no-body h2 {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    letter-spacing: -0.02em;
    color: #1c1917;
    margin: 0 0 1rem;
  }

  .no-body p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #57534e;
    max-width: 560px;
    margin: 0 0 1.5rem;
  }

  .no-body-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    background: var(--color-sun-pastel);
    color: #1e293b; /* texto oscuro sobre naranja pastel — AA (CIBA-2305) */
    font-weight: 600;
    border-radius: 9999px;
    text-decoration: none;
    min-height: 44px;
    transition: background 160ms ease;
  }

  .no-body-cta:hover {
    background: var(--color-sun-pastel-hover);
  }

  .no-body-back {
    margin-top: 1.5rem;
  }

  .no-body-back a {
    color: var(--color-teal-ink);
    font-weight: 600;
    text-decoration: none;
  }

  .no-body-back a:hover {
    text-decoration: underline;
  }

  @media (prefers-reduced-motion: reduce) {
    .no-body-cta {
      transition: none;
    }
  }
</style>
