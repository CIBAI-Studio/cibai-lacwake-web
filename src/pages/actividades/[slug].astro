---
import ActivityLayout from '../../layouts/ActivityLayout.astro';
import { getActivityContent } from '../../lib/cms';

/**
 * Ruta dinámica CMS-driven (CIBA-2522). Las 9 actividades con página estática
 * propia (kayak, wakeboard…) se sirven por sus rutas file-based, que tienen
 * prioridad sobre esta; aquí llegan sólo los slugs nuevos creados desde el
 * admin (`actividad_<slug>`) y los desconocidos (→ 404 real).
 */

// Slugs legacy que cambiaron de canónico: redirect permanente.
const LEGACY_REDIRECTS: Record<string, string> = {
  sup: '/actividades/paddle-surf',
};

const { slug } = Astro.params;

if (slug && slug in LEGACY_REDIRECTS) {
  return Astro.redirect(LEGACY_REDIRECTS[slug], 301);
}

const cms = slug && /^[a-z0-9_-]+$/.test(slug) ? await getActivityContent(slug) : null;

// Sin fila CMS y sin semilla → 404 real (ninguna ruta casa con /404 → error 404
// estándar del sitio, mismo comportamiento que cualquier URL inexistente).
if (!cms) {
  return Astro.rewrite('/404');
}

const cmsBody = cms.body ?? '';
---

<ActivityLayout
  title={cms.title}
  description={cms.description}
  image={cms.image ?? '/assets/images/hero-fallback.jpg'}
  imageAlt={cms.imageAlt ?? `${cms.title} en el pantano de la Baells`}
  tag={cms.tag}
  duration={cms.duration}
  minAge={cms.minAge}
  price={cms.price}
  included={cms.included ?? []}
>
  {cmsBody ? (
    <div class="cms-body" set:html={cmsBody} />
  ) : (
    <p>{cms.description}</p>
  )}
</ActivityLayout>
