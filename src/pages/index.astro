---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ActivitiesSection from '../components/sections/ActivitiesSection.astro';
import SectionDivider from '../components/SectionDivider.astro';
import { getHeroSlides, getWhyContent, getCtaContent, getSiteConfig, getHomeDividers, getHomeDecor } from '../lib/cms';
import type { DividerBoundary } from '../lib/cms';

const [heroCarousel, why, cta, siteConfig, dividers, decor] = await Promise.all([
  getHeroSlides(),
  getWhyContent(),
  getCtaContent(),
  getSiteConfig(),
  getHomeDividers(),
  getHomeDecor(),
]);

/* Decoración editable desde admin (contrato `home.decor`, CIBA-2581).
   Un slot cubre las N instancias de su decoración en la sección (la instancia
   espejada conserva su scaleX(-1) vía CSS); slot vacío ⇒ assets actuales. */
const featuresBranchLeft = decor.featuresBranch ?? '/assets/redesign/decor/botanica-teal.png';
const featuresBranchRight = decor.featuresBranch ?? '/assets/redesign/decor/botanica-margen.png';
const ctaWaves = decor.ctaWaves ?? '/assets/redesign/decor/agua-lateral.png';
const ctaBlobLeft = decor.ctaBlob ?? '/assets/redesign/decor/botanica-teal.png';
const ctaBlobRight = decor.ctaBlob ?? '/assets/redesign/decor/botanica-margen.png';

/* Banda de transición por costura: `bg` = color de la sección SALIENTE (arriba),
   `color` = relleno de la forma = color de la sección ENTRANTE (abajo). Así la
   onda/inclinación funde A→B sin cortes planos. El CMS puede forzar un relleno
   global único vía `home.dividers.color`. Colores tomados del CSS real de cada
   sección (design system claro). (CIBA-2346) */
const SECTION_INCOMING_COLOR: Record<DividerBoundary, string> = {
  'hero-activities': '#fdfcfa', // → Actividades (fondo papel)
  'activities-why': '#faf7f2', // → Features/Why (cream)
  'why-cta': '#1c818f', // → CTA aguamarina (--color-cta-aqua)
  footer: '#faf7f2', // → Footer (cream, --color-cream)
};
const SECTION_OUTGOING_COLOR: Record<DividerBoundary, string> = {
  'hero-activities': '#082f49', // Hero ↑ (lake-950)
  'activities-why': '#fdfcfa', // Actividades ↑
  'why-cta': '#faf7f2', // Features/Why ↑
  footer: '#1c818f', // CTA aguamarina ↑
};

const showDivider = (b: DividerBoundary) =>
  dividers.style !== 'none' && dividers.between.includes(b);
const dividerColor = (b: DividerBoundary) => dividers.color || SECTION_INCOMING_COLOR[b];
const dividerBg = (b: DividerBoundary) => SECTION_OUTGOING_COLOR[b];

/* Iconos SVG inline para las features (anti-emoji: CIBA-2304) */
const FEATURE_ICONS = [
  /* Entorno natural */
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <path d="M14 24c-5.523 0-10-3.134-10-7s4.477-7 10-7 10 3.134 10 7-4.477 7-10 7z" stroke="currentColor" stroke-width="1.75"/>
    <path d="M14 10V4m0 0L10.5 7.5M14 4l3.5 3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  /* Para toda la familia */
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <circle cx="10" cy="9" r="3" stroke="currentColor" stroke-width="1.75"/>
    <circle cx="18" cy="9" r="3" stroke="currentColor" stroke-width="1.75"/>
    <path d="M4 23c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
    <path d="M18 17c1.657 0 3 1.343 3 3v3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
    <circle cx="22" cy="14" r="2" stroke="currentColor" stroke-width="1.75"/>
  </svg>`,
  /* Flota en perfecto estado */
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <path d="M4 18l3-8h14l3 8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M2 21c2 2 4.5 2 6.5 0s4.5-2 6.5 0 4.5 2 6.5 0 4.5-2 6.5 0" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
    <path d="M14 10V6m0 0l-2 2m2-2l2 2" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  /* Fácil acceso */
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <path d="M14 3C10.134 3 7 6.134 7 10c0 5.25 7 15 7 15s7-9.75 7-15c0-3.866-3.134-7-7-7z" stroke="currentColor" stroke-width="1.75"/>
    <circle cx="14" cy="10" r="2.5" stroke="currentColor" stroke-width="1.75"/>
  </svg>`,
];
---

<BaseLayout
  title="Lacwake"
  description="Lacwake — 11 actividades acuáticas en el embalse de la Baells: kayak, wakeboard, wakesurf, esquí náutico, paddle surf, barcas y más. Reserva ahora por WhatsApp."
  seoKey="home"
>
  <!-- Hero fullscreen (carrusel multi-slide, CIBA-2217) — NO tocar -->
  <Hero slides={heroCarousel.slides} rotation={heroCarousel.rotation} />

  {showDivider('hero-activities') && (
    <SectionDivider
      style={dividers.style}
      color={dividerColor('hero-activities')}
      fromColor={dividerBg('hero-activities')}
      asset={dividers.asset}
      boundary="hero-activities"
    />
  )}

  <!-- Actividades: catálogo numerado 01/02/03 -->
  <ActivitiesSection whatsappUrl={siteConfig.whatsappUrl} />

  {showDivider('activities-why') && (
    <SectionDivider
      style={dividers.style}
      color={dividerColor('activities-why')}
      fromColor={dividerBg('activities-why')}
      asset={dividers.asset}
      flip
      boundary="activities-why"
    />
  )}

  <!-- Features: Naturaleza, agua y aventura -->
  <section class="features-section" aria-labelledby="features-title">
    <!-- Textura de agua/olas acuarela lateral (punto 3) -->
    <img
      src="/assets/redesign/decor/agua-lateral.png"
      alt=""
      aria-hidden="true"
      class="features-water"
      width="620"
      height="620"
      loading="lazy"
      decoding="async"
    />
    <!-- Rama botánica nítida, margen izquierdo (punto 3; slot CMS features_branch) -->
    <img
      src={featuresBranchLeft}
      alt=""
      aria-hidden="true"
      class="features-decor features-decor--left"
      width="360"
      height="620"
      loading="lazy"
      decoding="async"
    />
    <!-- Rama olivo+bayas nítida, margen derecho (punto 3; slot CMS features_branch) -->
    <img
      src={featuresBranchRight}
      alt=""
      aria-hidden="true"
      class="features-decor features-decor--right"
      width="360"
      height="620"
      loading="lazy"
      decoding="async"
    />
    <!-- Garza en la orilla, esquina inferior-izquierda (punto 3) -->
    <img
      src="/assets/redesign/decor/garza-orilla.png"
      alt=""
      aria-hidden="true"
      class="features-garza"
      width="420"
      height="520"
      loading="lazy"
      decoding="async"
    />

    <div class="container-site">
      <div class="features-layout">

        <!-- Texto izquierda -->
        <div class="features-text">
          <div class="section-overline">{why.label}</div>
          <h2 id="features-title" class="features-title">{why.title}</h2>
          <p class="features-body">{why.body1}</p>
          <p class="features-body">{why.body2}</p>
          <a
            href={siteConfig.whatsappUrl}
            class="btn-amber"
            target="_blank"
            rel="noopener noreferrer"
          >
            {why.ctaLabel}
          </a>
        </div>

        <!-- Grid de features derecha -->
        <div class="features-grid" role="list">
          {why.features.map((feat, i) => (
            <div class="feature-item" role="listitem">
              <div class="feature-icon-wrap" aria-hidden="true">
                <Fragment set:html={FEATURE_ICONS[i % FEATURE_ICONS.length]} />
              </div>
              <div class="feature-content">
                <div class="feature-title">{feat.title}</div>
                <div class="feature-desc">{feat.desc}</div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  {showDivider('why-cta') && (
    <SectionDivider
      style={dividers.style}
      color={dividerColor('why-cta')}
      fromColor={dividerBg('why-cta')}
      asset={dividers.asset}
      boundary="why-cta"
    />
  )}

  <!-- Franja de AGUA aguamarina antes del footer (punto 5) -->
  <section class="cta-banner" aria-labelledby="cta-title">
    <!-- Textura de agua/olas acuarela (decorativa, no bajo el texto; slot CMS cta_waves) -->
    <img
      src={ctaWaves}
      alt=""
      aria-hidden="true"
      class="cta-water cta-water--left"
      width="520"
      height="520"
      loading="lazy"
      decoding="async"
    />
    <img
      src={ctaWaves}
      alt=""
      aria-hidden="true"
      class="cta-water cta-water--right"
      width="520"
      height="520"
      loading="lazy"
      decoding="async"
    />
    <!-- Decoración de esquinas (como la referencia; slot CMS cta_blob) -->
    <img
      src={ctaBlobLeft}
      alt=""
      aria-hidden="true"
      class="cta-leaf cta-leaf--left"
      width="300"
      height="520"
      loading="lazy"
      decoding="async"
    />
    <img
      src={ctaBlobRight}
      alt=""
      aria-hidden="true"
      class="cta-leaf cta-leaf--right"
      width="300"
      height="520"
      loading="lazy"
      decoding="async"
    />

    <div class="container-site">
      <div class="cta-inner">
        <h2 id="cta-title" class="cta-title">{cta.title}</h2>
        <p class="cta-body">{cta.body}</p>
        <div class="cta-actions">
          <a
            href={siteConfig.whatsappUrl}
            class="btn-cta-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            {cta.primaryLabel}
          </a>
          <a href={cta.secondaryUrl} class="btn-cta-secondary">
            {cta.secondaryLabel}
          </a>
        </div>
        <p class="cta-contact">
          ¿Preguntas? Llámanos al{' '}
          <a href={siteConfig.phoneUrl} class="cta-phone">
            {siteConfig.phone}
          </a>
        </p>
      </div>
    </div>
  </section>

  {showDivider('footer') && (
    <SectionDivider
      style={dividers.style}
      color={dividerColor('footer')}
      fromColor={dividerBg('footer')}
      asset={dividers.asset}
      flip
      boundary="footer"
    />
  )}
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════════════════
     Features section
  ══════════════════════════════════════════════════════════════ */
  .features-section {
    position: relative;
    padding-block: 5.5rem;
    background: #faf7f2;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .features-section {
      padding-block: 7.5rem;
    }
  }

  /* Textura de agua acuarela lateral (punto 3) */
  .features-water {
    position: absolute;
    left: -6rem;
    top: -4rem;
    width: 300px;
    max-width: 45vw;
    opacity: 0.4;
    pointer-events: none;
    user-select: none;
    mix-blend-mode: multiply;
  }

  /* Decoraciones botánicas nítidas (raster, punto 3) */
  .features-decor {
    position: absolute;
    pointer-events: none;
    opacity: 0.9;
    user-select: none;
    z-index: 0;
  }

  .features-decor--left {
    left: -5rem;
    top: 3rem;
    width: 190px;
    max-width: 34vw;
  }

  .features-decor--right {
    right: -4rem;
    bottom: 1rem;
    width: 200px;
    max-width: 36vw;
    transform: scaleX(-1);
  }

  /* Garza en la orilla — esquina inferior-izquierda (punto 3) */
  .features-garza {
    position: absolute;
    left: 0.5rem;
    bottom: 0;
    width: 150px;
    max-width: 40vw;
    opacity: 0.95;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  @media (min-width: 1024px) {
    .features-decor--left {
      width: 250px;
      left: -3rem;
    }
    .features-decor--right {
      width: 260px;
      right: -2.5rem;
    }
    .features-garza {
      width: 230px;
      left: 1.5rem;
    }
    .features-water {
      width: 420px;
    }
  }

  /* El contenido va por encima de los decorativos */
  .features-section .container-site {
    position: relative;
    z-index: 1;
  }

  /* Layout split: texto izq + grid der */
  .features-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .features-layout {
      grid-template-columns: 5fr 7fr;
      gap: 5rem;
      align-items: center;
    }
  }

  /* Texto izquierda */
  .section-overline {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-teal-ink); /* teal-700 sobre cream: AA 5.12 */
    margin-bottom: 0.875rem;
  }

  .features-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: #1c1917;
    margin: 0 0 1.5rem;
    max-width: 480px;
  }

  .features-body {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #57534e;
    margin: 0 0 1.1rem;
  }

  .features-body:last-of-type {
    margin-bottom: 1.75rem;
  }

  /* Botón CTA */
  .btn-amber {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: var(--color-sun-pastel); /* naranja pastel (punto 7) */
    color: #1e293b; /* texto oscuro obligatorio — blanco falla AA (regla dura §D) */
    font-weight: 600;
    font-size: 1rem;
    border-radius: 9999px;
    text-decoration: none;
    min-height: 48px;
    transition: background 180ms ease, transform 140ms ease;
  }

  .btn-amber:hover {
    background: var(--color-sun-pastel-hover);
    transform: translateY(-2px);
  }

  .btn-amber:active {
    transform: translateY(0);
  }

  /* Grid de features */
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }

  @media (min-width: 480px) {
    .features-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .feature-icon-wrap {
    flex-shrink: 0;
    width: 2.75rem;
    height: 2.75rem;
    background: #ffffff;
    border: 1px solid #d3e7e4;
    border-radius: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-teal-ink); /* iconos grid Naturaleza en teal (punto 7) */
    box-shadow: 0 1px 4px rgba(15, 118, 110, 0.08);
  }

  .feature-content {
    flex: 1;
    min-width: 0;
  }

  .feature-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9375rem;
    color: #1c1917;
    margin-bottom: 0.3rem;
    line-height: 1.3;
  }

  .feature-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #475569;
  }

  /* ═══════════════════════════════════════════════════════════════
     CTA Banner turquesa
  ══════════════════════════════════════════════════════════════ */
  .cta-banner {
    position: relative;
    padding-block: 5rem;
    /* Ancla sólida #1C818F garantiza AA para texto blanco (4.58) a cualquier
       tamaño. El aguamarina claro decorativo se confina al borde superior
       (fuera del bloque de texto centrado) — regla dura §D pt 5. */
    background-color: var(--color-cta-aqua);
    background-image: radial-gradient(
      85% 55% at 50% -12%,
      var(--color-cta-aqua-lite) 0%,
      rgba(28, 129, 143, 0) 62%
    );
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .cta-banner {
      padding-block: 6.5rem;
    }
  }

  /* Textura de agua acuarela en los laterales (decorativa) */
  .cta-water {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 340px;
    max-width: 40vw;
    opacity: 0.28;
    pointer-events: none;
    user-select: none;
    mix-blend-mode: screen;
  }
  .cta-water--left { left: -4rem; }
  .cta-water--right { right: -4rem; transform: translateY(-50%) scaleX(-1); }

  /* Ramas botánicas en las esquinas (como la referencia) */
  .cta-leaf {
    position: absolute;
    width: 170px;
    max-width: 30vw;
    opacity: 0.85;
    pointer-events: none;
    user-select: none;
  }
  .cta-leaf--left { left: -3rem; bottom: -1.5rem; }
  .cta-leaf--right { right: -3rem; top: -1.5rem; transform: scaleX(-1) rotate(4deg); }

  @media (min-width: 1024px) {
    .cta-leaf { width: 220px; }
  }

  @media (max-width: 639px) {
    .cta-leaf { display: none; }
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 680px;
    margin-inline: auto;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(1.875rem, 4.5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: #ffffff;
    margin: 0 0 1rem;
  }

  .cta-body {
    font-size: 1.125rem;
    color: #ffffff; /* AA 4.63:1 sobre cta-aqua #1C818F (rgba opaco fallaba a 4.23:1) */
    margin: 0 0 2.25rem;
    line-height: 1.65;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  /* Botón primario: naranja pastel sobre aguamarina (punto 7) */
  .btn-cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 2rem;
    background: var(--color-sun-pastel);
    color: #1e293b; /* texto oscuro obligatorio (regla dura §D) */
    font-weight: 700;
    font-size: 1rem;
    border-radius: 9999px;
    text-decoration: none;
    min-height: 48px;
    transition: background 180ms ease, transform 140ms ease;
  }

  .btn-cta-primary:hover {
    background: var(--color-sun-pastel-hover);
    transform: translateY(-2px);
  }

  .btn-cta-primary:active {
    transform: translateY(0);
  }

  /* Botón secundario: contorno blanco */
  .btn-cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 1.75rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    color: white;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 9999px;
    text-decoration: none;
    min-height: 48px;
    transition: background 180ms ease;
  }

  .btn-cta-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .cta-contact {
    font-size: 0.9375rem;
    color: #ffffff; /* AA 4.63:1 sobre cta-aqua #1C818F (rgba opaco fallaba a 3.99:1) */
    margin: 0;
  }

  .cta-phone {
    color: #ffffff;
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.45);
    text-underline-offset: 2px;
    transition: text-decoration-color 150ms ease;
  }

  .cta-phone:hover {
    text-decoration-color: rgba(255, 255, 255, 0.9);
  }
</style>
