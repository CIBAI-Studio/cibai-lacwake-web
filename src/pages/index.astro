---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ActivitiesSection from '../components/sections/ActivitiesSection.astro';
import { getHeroContent, getWhyContent, getCtaContent, getSiteConfig } from '../lib/cms';

const [hero, why, cta, siteConfig] = await Promise.all([
  getHeroContent(),
  getWhyContent(),
  getCtaContent(),
  getSiteConfig(),
]);
---

<BaseLayout
  title="Lacwake"
  description="Lacwake — Actividades acuáticas en el pantano: kayak, hidropedales y barcas para toda la familia. Reserva ahora y vive la aventura."
>
  <!-- Hero fullscreen -->
  <Hero
    title={hero.title}
    subtitle={hero.subtitle}
    videoSrc={hero.videoUrl}
    fallbackImage={hero.fallbackImage}
    ctaUrl={hero.ctaUrl}
    ctaLabel={hero.ctaLabel}
    ctaSecondaryLabel={hero.ctaSecondaryLabel}
    ctaSecondaryUrl={hero.ctaSecondaryUrl}
  />

  <!-- Actividades -->
  <ActivitiesSection />

  <!-- Por qué Lacwake -->
  <section class="why-section" aria-labelledby="why-title">
    <div class="container-site">
      <div class="why-grid">
        <div class="why-text">
          <div class="section-label">{why.label}</div>
          <h2 id="why-title" class="why-title">
            {why.title}
          </h2>
          <p class="why-body">{why.body1}</p>
          <p class="why-body">{why.body2}</p>
          <a
            href={siteConfig.whatsappUrl}
            class="btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            {why.ctaLabel}
          </a>
        </div>

        <div class="why-features" role="list">
          {why.features.map(({ icon, title, desc }) => (
            <div class="why-feature" role="listitem">
              <div class="feature-icon" aria-hidden="true">{icon}</div>
              <div class="feature-title">{title}</div>
              <div class="feature-desc">{desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="cta-section" aria-labelledby="cta-title">
    <div class="container-site">
      <div class="cta-box">
        <h2 id="cta-title" class="cta-title">
          {cta.title}
        </h2>
        <p class="cta-body">
          {cta.body}
        </p>
        <div class="cta-actions">
          <a
            href={siteConfig.whatsappUrl}
            class="btn-cta-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            {cta.primaryLabel}
          </a>
          <a href={cta.secondaryUrl} class="btn-cta-secondary">
            {cta.secondaryLabel}
          </a>
        </div>
        <p class="cta-contact">
          ¿Tienes dudas? Llámanos al{' '}
          <a href={siteConfig.phoneUrl} class="cta-phone">
            {siteConfig.phone}
          </a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Why section */
  .why-section {
    padding-block: 5rem;
    background: white;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .why-section {
      padding-block: 7rem;
    }
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .why-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
  }

  .section-label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0284c7;
    margin-bottom: 0.75rem;
  }

  .why-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0c0a09;
    margin: 0 0 1.5rem;
    max-width: 480px;
  }

  .why-body {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #57534e;
    margin: 0 0 1.25rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    margin-top: 1rem;
    padding: 0.875rem 2rem;
    background: #f59e0b;
    color: white;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: background 200ms ease, transform 150ms ease;
    min-height: 48px;
  }

  .btn-primary:hover {
    background: #d97706;
    transform: translateY(-2px);
  }

  .why-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .why-feature {
    padding: 1.5rem;
    background: #f0f9ff;
    border-radius: 1rem;
    border: 1px solid #bae6fd;
  }

  .feature-icon {
    font-size: 1.75rem;
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .feature-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    color: #0c4a6e;
    margin-bottom: 0.4rem;
  }

  .feature-desc {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: #0369a1;
  }

  /* CTA section */
  .cta-section {
    padding-block: 5rem;
    background: #082f49;
  }

  .cta-box {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
  }

  .cta-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: white;
    margin: 0 0 1rem;
  }

  .cta-body {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.7);
    margin: 0 0 2rem;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .btn-cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: #f59e0b;
    color: white;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: background 200ms ease, transform 150ms ease;
    min-height: 48px;
  }

  .btn-cta-primary:hover {
    background: #d97706;
    transform: translateY(-2px);
  }

  .btn-cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.75rem;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: background 200ms ease;
    min-height: 48px;
  }

  .btn-cta-secondary:hover {
    background: rgba(255,255,255,0.18);
  }

  .cta-contact {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.55);
    margin: 0;
  }

  .cta-phone {
    color: #38bdf8;
    font-weight: 600;
    text-decoration: none;
    transition: color 150ms ease;
  }

  .cta-phone:hover {
    color: white;
  }
</style>
