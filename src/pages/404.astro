---
import BaseLayout from '../layouts/BaseLayout.astro';

/**
 * Página 404 propia (CIBA-2526). Astro la sirve para toda ruta sin match y
 * la ruta dinámica /actividades/[slug] hace `Astro.rewrite('/404')` cuando la
 * ficha no existe en el CMS. Fijamos el status por si el rewrite no lo hereda.
 */
Astro.response.status = 404;
---

<BaseLayout title="Página no encontrada" description="La página que buscas no existe." noIndex>
  <section class="nf">
    <div class="container-site">
      <p class="nf-code" aria-hidden="true">404</p>
      <h1 class="nf-title">Esta orilla no existe</h1>
      <p class="nf-lead">
        La página que buscas no está en el pantano. Puede que el enlace haya
        cambiado o que la actividad ya no esté disponible.
      </p>
      <div class="nf-actions">
        <a href="/" class="nf-cta">Volver al inicio</a>
        <a href="/#actividades" class="nf-link">Ver actividades</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    min-height: calc(100dvh - 12rem);
    display: flex;
    align-items: center;
    padding-block: 8rem 5rem;
    background:
      radial-gradient(60% 40% at 88% 6%, #eaf3f1 0%, rgba(234, 243, 241, 0) 60%),
      #fdfcfa;
  }

  .nf-code {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 14vw, 8rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.05em;
    color: transparent;
    -webkit-text-stroke: 2px var(--color-teal-pastel);
    margin: 0 0 1rem;
  }

  .nf-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #1c1917;
    margin: 0 0 1rem;
  }

  .nf-lead {
    font-size: 1.075rem;
    line-height: 1.65;
    color: #57534e;
    max-width: 480px;
    margin: 0 0 2rem;
  }

  .nf-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .nf-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    background: var(--color-sun-pastel);
    color: #1e293b; /* AA sobre naranja pastel (CIBA-2305) */
    font-weight: 600;
    border-radius: 9999px;
    text-decoration: none;
    min-height: 44px;
    transition: background 160ms ease;
  }

  .nf-cta:hover {
    background: var(--color-sun-pastel-hover);
  }

  .nf-link {
    color: var(--color-teal-ink);
    font-weight: 600;
    text-decoration: none;
  }

  .nf-link:hover {
    text-decoration: underline;
  }

  @media (prefers-reduced-motion: reduce) {
    .nf-cta {
      transition: none;
    }
  }
</style>
