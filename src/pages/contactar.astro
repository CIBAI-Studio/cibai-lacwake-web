---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteConfig } from '../lib/cms';

const siteConfig = await getSiteConfig();
const LAT_LNG: [number, number] = [42.1460, 1.8760];
---

<BaseLayout
  title="Contactar"
  description="Contacta con Lacwake. Teléfono, email y ubicación del pantano. Estamos aquí para ayudarte a planificar tu aventura acuática."
>
  <div class="contact-page">

    <!-- Header -->
    <div class="contact-header">
      <div class="container-site">
        <nav class="breadcrumb" aria-label="Navegación por ruta">
          <ol role="list">
            <li><a href="/">Inicio</a></li>
            <li aria-hidden="true">›</li>
            <li aria-current="page">Contactar</li>
          </ol>
        </nav>
        <h1 class="contact-title">¿Hablamos?</h1>
        <p class="contact-lead">
          Estamos aquí para ayudarte. Contáctanos por WhatsApp, teléfono o email
          y te responderemos lo antes posible.
        </p>
      </div>
    </div>

    <!-- Content -->
    <div class="container-site contact-body">
      <div class="contact-grid">

        <!-- Contact info -->
        <div class="contact-info">

          <div class="contact-card">
            <div class="contact-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.36 12 19.79 19.79 0 0 1 1.22 3.18 2 2 0 0 1 3.2 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.1a16 16 0 0 0 6 6l.62-.61a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"></path>
              </svg>
            </div>
            <div class="contact-detail">
              <h2 class="contact-card-title">Teléfono / WhatsApp</h2>
              <a href={siteConfig.phoneUrl} class="contact-link contact-link-primary">
                {siteConfig.phone}
              </a>
              <p class="contact-note">Lunes a domingo, 9:00 – 20:00 (temporada)</p>
            </div>
          </div>

          <div class="contact-card">
            <div class="contact-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
            </div>
            <div class="contact-detail">
              <h2 class="contact-card-title">Email</h2>
              <a href={siteConfig.emailUrl} class="contact-link contact-link-primary">
                {siteConfig.email}
              </a>
              <p class="contact-note">Respondemos en menos de 24 horas</p>
            </div>
          </div>

          <div class="contact-card">
            <div class="contact-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <div class="contact-detail">
              <h2 class="contact-card-title">Ubicación</h2>
              <p class="contact-address">{siteConfig.address}</p>
              <p class="contact-note">Parking gratuito. A 1h de las principales ciudades.</p>
            </div>
          </div>

          <div class="contact-card">
            <div class="contact-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <div class="contact-detail">
              <h2 class="contact-card-title">Horario</h2>
              <p class="contact-address">{siteConfig.schedule}</p>
              <p class="contact-note">Temporada: mayo – octubre</p>
            </div>
          </div>

          <!-- Reserve CTA -->
          <div class="contact-cta-box">
            <p class="contact-cta-text">¿Listo para reservar? El método más rápido es WhatsApp:</p>
            <a
              href={siteConfig.whatsappUrl}
              class="contact-cta-btn"
              target="_blank"
              rel="noopener noreferrer"
            >
              {siteConfig.whatsappLabel} vía WhatsApp
            </a>
          </div>

        </div>

        <!-- Map placeholder -->
        <div class="map-section" aria-label="Mapa de ubicación">
          <div class="map-placeholder">
            <div class="map-placeholder-inner" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#0284c7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              <p>Embalse de la Baells</p>
              <span>Cercs (Berguedà, Barcelona)</span>
            </div>
            <a
              href={`https://maps.google.com/maps?q=${LAT_LNG[0]},${LAT_LNG[1]}&z=13`}
              target="_blank"
              rel="noopener noreferrer"
              class="map-link"
              aria-label="Ver en Google Maps — abre en nueva pestaña"
            >
              Ver en Google Maps →
            </a>
          </div>

          <!-- Info adicional -->
          <div class="how-to-get">
            <h3 class="how-title">Cómo llegar</h3>
            <ul class="how-list" role="list">
              <li>
                <strong>Desde Barcelona:</strong> C-16 dirección Berga/Manresa, salida Cercs (Berguedà). 1h 30 min aproximadamente.
              </li>
              <li>
                <strong>Desde Manresa:</strong> C-16 dirección Berga hasta la salida de Cercs. 45 min aproximadamente.
              </li>
              <li>
                <strong>Transporte público:</strong> Bus hasta Berga y trayecto local hasta el embalse (consultar horarios de temporada).
              </li>
              <li>
                <strong>Parking:</strong> Gratuito en las instalaciones de Lacwake.
              </li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-page {
    min-height: 100dvh;
    background: #fafaf9;
  }

  .contact-header {
    background: linear-gradient(135deg, #082f49 0%, #0c4a6e 100%);
    padding-top: 7rem;
    padding-bottom: 4rem;
  }

  .breadcrumb ol {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .breadcrumb a:hover {
    color: white;
  }

  .contact-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: white;
    margin: 0 0 1rem;
    line-height: 1.1;
  }

  .contact-lead {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    max-width: 560px;
    margin: 0;
  }

  .contact-body {
    padding-block: 4rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    background: white;
    border: 1px solid #e7e5e4;
    border-radius: 1rem;
    box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    align-items: flex-start;
  }

  .contact-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    background: #e0f2fe;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0284c7;
  }

  .contact-detail {
    flex: 1;
  }

  .contact-card-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: #0c0a09;
    margin: 0 0 0.4rem;
  }

  .contact-link {
    text-decoration: none;
    font-size: 1.0625rem;
    font-weight: 600;
    display: inline-block;
    margin-bottom: 0.3rem;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    transition: color 150ms ease;
  }

  .contact-link-primary {
    color: #0284c7;
  }

  .contact-link-primary:hover {
    color: #0369a1;
    text-decoration: underline;
  }

  .contact-note {
    font-size: 0.875rem;
    color: #a8a29e;
    margin: 0;
  }

  .contact-address {
    font-size: 1.0625rem;
    font-weight: 600;
    color: #292524;
    margin: 0 0 0.3rem;
  }

  .contact-cta-box {
    padding: 1.75rem;
    background: linear-gradient(135deg, #082f49, #0369a1);
    border-radius: 1rem;
    text-align: center;
  }

  .contact-cta-text {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.8);
    margin: 0 0 1rem;
  }

  .contact-cta-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.75rem;
    background: #f59e0b;
    color: white;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: background 200ms ease;
    min-height: 48px;
  }

  .contact-cta-btn:hover {
    background: #d97706;
  }

  /* Map */
  .map-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .map-placeholder {
    background: #e0f2fe;
    border-radius: 1.25rem;
    min-height: 320px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    border: 1px solid #bae6fd;
    position: relative;
    overflow: hidden;
  }

  .map-placeholder-inner {
    text-align: center;
  }

  .map-placeholder-inner p {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: #0284c7;
    margin: 0.75rem 0 0.25rem;
  }

  .map-placeholder-inner span {
    font-size: 0.9375rem;
    color: #0369a1;
  }

  .map-link {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    padding: 0.5rem 1rem;
    background: white;
    color: #0284c7;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 0.5rem;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    transition: box-shadow 150ms ease;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  .map-link:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }

  .how-to-get {
    padding: 1.75rem;
    background: white;
    border: 1px solid #e7e5e4;
    border-radius: 1rem;
  }

  .how-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: #0c0a09;
    margin: 0 0 1rem;
  }

  .how-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .how-list li {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: #57534e;
    padding-left: 1rem;
    border-left: 2px solid #bae6fd;
  }

  .how-list strong {
    color: #0c0a09;
  }
</style>
