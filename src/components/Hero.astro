---
import HeroAnimated from './react/HeroAnimated';
import { resolveHeroFont } from '../lib/heroFonts';
import type { HeroContent } from '../lib/cms';

type HeroConfig = Partial<Pick<HeroContent, 'overline' | 'layout' | 'typography' | 'video'>>;

interface Props extends HeroConfig {
  title?: string;
  subtitle?: string;
  videoSrc?: string;
  fallbackImage?: string;
  ctaUrl?: string;
  ctaLabel?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryUrl?: string;
}

const {
  title = 'Tu aventura empieza en el agua',
  subtitle = 'Kayak, wake, esquí náutico y paseos en el embalse de la Baells. El pantano te espera.',
  videoSrc = '/assets/redesign/hero-baells.mp4',
  fallbackImage = '/assets/redesign/wakeboard.webp',
  ctaUrl,
  ctaLabel,
  ctaSecondaryLabel,
  ctaSecondaryUrl,
  overline = 'Actividades acuáticas',
  layout = { h: 'left', v: 'bottom' },
  typography,
  video,
} = Astro.props;

// Defaults de seguridad (index.astro siempre los pasa desde el CMS).
const typo = typography ?? {
  title: { font: 'anton', size: 76, color: '#FFFFFF', accentColor: '#f59e0b' },
  subtitle: { font: 'inter', size: 20, color: '#E2E8F0' },
  button: { font: 'inter', size: 16, textColor: '#0B1120', bgColor: '#f59e0b' },
};
const vid = video ?? { preload: 'auto' as const, loop: true, soundIntent: 'on' as const };

const titleFont = resolveHeroFont(typo.title.font, 'anton');
const subtitleFont = resolveHeroFont(typo.subtitle.font, 'inter');
const buttonFont = resolveHeroFont(typo.button.font, 'inter');

// Tamaño en px → clamp fluido: escala con el viewport pero nunca supera el valor
// pedido (evita romper móvil). El título mantiene un piso legible.
const titleSize = `clamp(2.5rem, ${(typo.title.size / 12).toFixed(2)}vw, ${typo.title.size}px)`;
const subtitleSize = `clamp(1rem, ${(typo.subtitle.size / 16).toFixed(2)}vw, ${typo.subtitle.size}px)`;
const buttonSize = `${typo.button.size}px`;

const heroVars = [
  `--hero-title-font:${titleFont.family}`,
  `--hero-title-size:${titleSize}`,
  `--hero-title-color:${typo.title.color}`,
  `--hero-title-accent:${typo.title.accentColor}`,
  `--hero-subtitle-font:${subtitleFont.family}`,
  `--hero-subtitle-size:${subtitleSize}`,
  `--hero-subtitle-color:${typo.subtitle.color}`,
  `--hero-btn-font:${buttonFont.family}`,
  `--hero-btn-size:${buttonSize}`,
  `--hero-btn-text-color:${typo.button.textColor}`,
  `--hero-btn-bg:${typo.button.bgColor}`,
].join(';');
---

<!-- Preload de la variante de título (self-host) para minimizar el FOUT. -->
<link rel="preload" href={titleFont.file} as="font" type="font/woff2" crossorigin />

<section
  class="hero"
  data-h={layout.h}
  data-v={layout.v}
  data-sound-intent={vid.soundIntent}
  style={heroVars}
  aria-label="Imagen principal"
>
  <!-- Background video -->
  <div class="hero-media" aria-hidden="true">
    <video
      class="hero-video"
      autoplay
      muted
      loop={vid.loop}
      playsinline
      poster={fallbackImage}
      preload={vid.preload}
    >
      <source src={videoSrc} type="video/mp4" />
    </video>
    <!-- Fallback visible si no hay vídeo -->
    <img
      class="hero-fallback"
      src={fallbackImage}
      alt=""
      aria-hidden="true"
      width="1920"
      height="1080"
      loading="eager"
    />
    <!-- Overlay -->
    <div class="hero-overlay" aria-hidden="true"></div>
  </div>

  <!-- Animated content (React) -->
  <div class="hero-content-wrapper">
    <HeroAnimated
      client:load
      overline={overline}
      title={title}
      subtitle={subtitle}
      reserveUrl={ctaUrl}
      reserveLabel={ctaLabel}
      reserveSecondaryLabel={ctaSecondaryLabel}
      reserveSecondaryUrl={ctaSecondaryUrl}
    />
  </div>

  <!-- Control de sonido: autoplay siempre muted; el usuario activa el audio -->
  <button
    type="button"
    class="hero-sound"
    hidden
    aria-pressed="false"
    aria-label="Activar sonido del vídeo"
  >
    <!-- Icono: sonido silenciado (estado inicial) -->
    <svg class="hero-sound-icon hero-sound-icon--muted" viewBox="0 0 24 24" fill="none" aria-hidden="true" width="22" height="22">
      <path d="M11 5 6 9H2v6h4l5 4V5Z" fill="currentColor" />
      <path d="m16 9 5 6M21 9l-5 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
    </svg>
    <!-- Icono: sonido activo -->
    <svg class="hero-sound-icon hero-sound-icon--on" viewBox="0 0 24 24" fill="none" aria-hidden="true" width="22" height="22">
      <path d="M11 5 6 9H2v6h4l5 4V5Z" fill="currentColor" />
      <path d="M15.5 8.5a5 5 0 0 1 0 7M18.5 5.5a9 9 0 0 1 0 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
    </svg>
    <span class="hero-sound-label">Activar sonido</span>
  </button>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    /* Posición vertical del contenido (layout.v) — default: abajo. */
    justify-content: flex-end;
    align-items: stretch;
    overflow: hidden;
    background: #082f49;
  }

  /* Posición vertical (layout.v) → eje principal de la columna */
  .hero[data-v='top'] { justify-content: flex-start; }
  .hero[data-v='center'] { justify-content: center; }
  .hero[data-v='bottom'] { justify-content: flex-end; }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    /* Ocultar imagen si el vídeo se carga correctamente */
  }

  /* Solo ocultar fallback si el vídeo no tiene poster definido */
  .hero-video:not([poster]) ~ .hero-fallback {
    display: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.28) 45%,
      rgba(0, 0, 0, 0.65) 100%
    );
  }

  .hero-content-wrapper {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    /* Posición horizontal del bloque de contenido (layout.h) — default: izq. */
    align-items: flex-start;
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 1.25rem;
    padding-block: 6rem 4rem;
  }

  /* Posición horizontal (layout.h) → alineación del bloque en el eje cruzado */
  .hero[data-h='left'] .hero-content-wrapper { align-items: flex-start; }
  .hero[data-h='center'] .hero-content-wrapper { align-items: center; }
  .hero[data-h='right'] .hero-content-wrapper { align-items: flex-end; }

  @media (min-width: 768px) {
    .hero-content-wrapper {
      padding-inline: 2rem;
    }
  }

  /* Control de sonido */
  .hero-sound {
    position: absolute;
    top: max(1.25rem, env(safe-area-inset-top));
    right: max(1.25rem, env(safe-area-inset-right));
    z-index: 20;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 48px;
    min-width: 48px;
    padding: 0 0.875rem;
    /* Fondo oscuro sólido (no depende del vídeo) → contraste AA garantizado */
    background: rgba(8, 47, 73, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 9999px;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: background 200ms ease, border-color 200ms ease, transform 150ms ease;
  }

  .hero-sound[hidden] {
    display: none;
  }

  .hero-sound:hover {
    background: rgba(8, 47, 73, 0.9);
    border-color: rgba(255, 255, 255, 0.6);
    transform: translateY(-1px);
  }

  .hero-sound:focus-visible {
    outline: 3px solid var(--color-sun-400, #fbbf24);
    outline-offset: 2px;
  }

  .hero-sound-icon {
    flex-shrink: 0;
  }

  /* Estado por defecto (muted): mostrar icono "muted", ocultar "on" */
  .hero-sound-icon--on {
    display: none;
  }

  .hero-sound[aria-pressed='true'] .hero-sound-icon--muted {
    display: none;
  }

  .hero-sound[aria-pressed='true'] .hero-sound-icon--on {
    display: inline;
  }

  .hero-sound-label {
    white-space: nowrap;
  }

  /* Pulso de atención inicial mientras el vídeo está en silencio */
  .hero-sound[aria-pressed='false'] {
    animation: soundPulse 2.4s ease-in-out infinite;
  }

  @keyframes soundPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0); }
    50% { box-shadow: 0 0 0 6px rgba(245, 158, 11, 0.18); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-sound[aria-pressed='false'] {
      animation: none;
    }
  }

  @media (max-width: 480px) {
    /* En móvil: control compacto (solo icono) para no invadir el hero */
    .hero-sound {
      padding: 0;
      width: 48px;
      justify-content: center;
    }
    .hero-sound-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,0.5));
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-line {
      animation: none;
      opacity: 0.5;
    }
  }
</style>

<style is:global>
  /* Estilos del componente React HeroAnimated */
  .hero-content {
    display: flex;
    flex-direction: column;
    /* Alineación del texto/acciones según layout.h (default: izquierda) */
    align-items: flex-start;
    text-align: left;
    gap: 1.5rem;
    max-width: 820px;
  }

  .hero[data-h='left'] .hero-content { align-items: flex-start; text-align: left; }
  .hero[data-h='center'] .hero-content { align-items: center; text-align: center; }
  .hero[data-h='right'] .hero-content { align-items: flex-end; text-align: right; }

  /* Overline en versalitas con tracking (accent configurable). Sin pill:
     editorial y legible sobre el vídeo gracias al text-shadow. */
  .hero-tag {
    display: inline-block;
    color: var(--hero-title-accent, #fbbf24);
    font-family: var(--hero-subtitle-font, var(--font-body));
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
  }

  .hero-title {
    font-family: var(--hero-title-font, var(--font-heading));
    font-size: var(--hero-title-size, clamp(2.5rem, 7.5vw, 5.75rem));
    font-weight: 700;
    line-height: 1.05;
    color: var(--hero-title-color, white);
    letter-spacing: -0.02em;
    max-width: 15ch;
    margin: 0;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
  }

  .hero-subtitle {
    font-family: var(--hero-subtitle-font, var(--font-body));
    font-size: var(--hero-subtitle-size, clamp(1rem, 2vw, 1.25rem));
    color: var(--hero-subtitle-color, rgba(255, 255, 255, 0.8));
    line-height: 1.6;
    max-width: 46ch;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: flex-start;
    margin-top: 0.5rem;
  }

  .hero[data-h='left'] .hero-actions { justify-content: flex-start; }
  .hero[data-h='center'] .hero-actions { justify-content: center; }
  .hero[data-h='right'] .hero-actions { justify-content: flex-end; }

  .btn-reserve {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: var(--hero-btn-bg, #f59e0b);
    color: var(--hero-btn-text-color, white);
    font-family: var(--hero-btn-font, var(--font-body));
    font-weight: 600;
    font-size: var(--hero-btn-size, 1rem);
    border-radius: 9999px;
    text-decoration: none;
    transition: transform 150ms ease, box-shadow 200ms ease, filter 200ms ease;
    min-height: 48px;
  }

  /* Hover independiente del color de fondo configurado (funciona con cualquier bg) */
  .btn-reserve:hover {
    transform: translateY(-2px);
    filter: brightness(0.94);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.28);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.75rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: white;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 9999px;
    text-decoration: none;
    backdrop-filter: blur(8px);
    transition: background 200ms ease, border-color 200ms ease;
    min-height: 48px;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.4);
  }
</style>

<script>
  const hero = document.querySelector<HTMLElement>('.hero');
  const video = document.querySelector<HTMLVideoElement>('.hero-video');
  const fallback = document.querySelector<HTMLElement>('.hero-fallback');
  const soundBtn = document.querySelector<HTMLButtonElement>('.hero-sound');
  const soundLabel = soundBtn?.querySelector<HTMLElement>('.hero-sound-label');

  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches;
  const soundIntentOn = hero?.dataset.soundIntent === 'on';

  const playSafe = () => {
    if (!video) return;
    const p = video.play();
    if (p && typeof p.catch === 'function') p.catch(() => {});
  };

  if (video && fallback) {
    video.addEventListener('canplay', () => {
      fallback.style.display = 'none';
    });
  }

  if (video) {
    // preload="auto" bufferiza; arrancamos explícitamente en cuanto hay datos
    // suficientes (no dependemos solo del atributo autoplay).
    video.addEventListener('canplay', playSafe, { once: true });
    video.addEventListener('loadeddata', playSafe, { once: true });
    if (video.readyState >= 2) playSafe();
  }

  if (video && soundBtn && soundLabel) {
    // El control solo tiene sentido si el vídeo puede reproducirse.
    // Si el vídeo falla, el fallback_image cubre y el botón permanece oculto.
    const showControl = () => {
      soundBtn.hidden = false;
    };
    video.addEventListener('canplay', showControl, { once: true });
    if (video.readyState >= 2) showControl();

    video.addEventListener('error', () => {
      soundBtn.hidden = true;
    });

    const setState = (soundOn: boolean) => {
      video.muted = !soundOn;
      soundBtn.setAttribute('aria-pressed', String(soundOn));
      soundBtn.setAttribute(
        'aria-label',
        soundOn ? 'Silenciar vídeo' : 'Activar sonido del vídeo',
      );
      soundLabel.textContent = soundOn ? 'Silenciar' : 'Activar sonido';
    };

    soundBtn.addEventListener('click', () => {
      const soundOn = video.muted; // si estaba muted, pasamos a con sonido
      setState(soundOn);
      // Reanudar reproducción (el navegador la permite tras el gesto del usuario).
      playSafe();
    });

    // Si el navegador silencia el vídeo por su cuenta, reflejarlo en el control.
    video.addEventListener('volumechange', () => {
      const soundOn = !video.muted;
      if (soundBtn.getAttribute('aria-pressed') !== String(soundOn)) {
        setState(soundOn);
      }
    });

    // sound_intent = "on": auto-unmute en el PRIMER gesto del usuario. Ningún
    // navegador permite audio automático "en frío" (MEI), pero sí tras cualquier
    // interacción. Respetamos prefers-reduced-motion: no forzamos audio.
    if (soundIntentOn && !prefersReducedMotion) {
      const ac = new AbortController();
      const unmuteOnGesture = () => {
        if (!video.muted) {
          ac.abort();
          return;
        }
        setState(true);
        playSafe();
        ac.abort(); // un único disparo: retira todos los listeners
      };
      const arm = () => {
        for (const ev of ['pointerdown', 'touchstart', 'keydown', 'scroll', 'wheel']) {
          document.addEventListener(ev, unmuteOnGesture, {
            once: true,
            passive: true,
            signal: ac.signal,
          });
        }
      };
      video.addEventListener('canplay', arm, { once: true });
      if (video.readyState >= 2) arm();
    }
  }
</script>
