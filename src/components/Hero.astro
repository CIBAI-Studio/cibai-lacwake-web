---
import HeroCarousel from './react/HeroCarousel';
import { resolveHeroFont } from '../lib/heroFonts';
import type { HeroSlide, HeroRotation } from '../lib/cms';

interface Props {
  slides: HeroSlide[];
  rotation: HeroRotation;
}

const { slides, rotation } = Astro.props;
const isMulti = slides.length >= 2;

// Preload de la fuente de título del PRIMER slide (minimiza FOUT del LCP).
const firstTitleFont = resolveHeroFont(slides[0]?.typography.title.font ?? 'anton', 'anton');
---

<!-- Preload de la variante de título del slide inicial (self-host). -->
<link rel="preload" href={firstTitleFont.file} as="font" type="font/woff2" crossorigin />

<section
  class="hero"
  aria-roledescription={isMulti ? 'carrusel' : undefined}
  aria-label="Imagen principal"
>
  {isMulti && <h2 class="sr-only">Carrusel de presentación</h2>}
  <HeroCarousel client:load slides={slides} rotation={rotation} />
</section>

<style is:global>
  /* ─── Estructura del hero (React island render → estilos globales) ─── */
  .hero {
    position: relative;
    min-height: 100dvh;
    overflow: hidden;
    background: #082f49;
  }

  .hero-carousel {
    position: absolute;
    inset: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ─── Capa de media + crossfade ─── */
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-slide-media {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition-property: opacity;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    /* transition-duration se aplica inline (0 en reduced-motion) */
  }

  .hero-slide-media[data-active='true'] {
    opacity: 1;
  }

  .hero-video,
  .hero-slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* La variante 9:16 móvil envuelve la img en <picture> (CIBA-2559);
     display:contents mantiene el sizing 100% contra .hero-slide-media. */
  .hero-slide-media picture {
    display: contents;
  }

  /* La imagen fallback del vídeo la pinta el atributo `poster` del <video>
     (ver HeroCarousel), no un <img> superpuesto — evita tapar el vídeo. */

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.28) 45%,
      rgba(0, 0, 0, 0.65) 100%
    );
  }

  /* ─── Capa de contenido (texto por-slide) ─── */
  .hero-content-layer {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    pointer-events: none;
  }

  /* Posición vertical (layout.v) */
  .hero-content-layer[data-v='top'] { justify-content: flex-start; }
  .hero-content-layer[data-v='center'] { justify-content: center; }
  .hero-content-layer[data-v='bottom'] { justify-content: flex-end; }

  .hero-content-wrapper {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 1.25rem;
    padding-block: 6rem 4rem;
  }

  /* Posición horizontal (layout.h) del bloque de texto */
  .hero-content-layer[data-h='left'] .hero-content-wrapper { align-items: flex-start; }
  .hero-content-layer[data-h='center'] .hero-content-wrapper { align-items: center; }
  .hero-content-layer[data-h='right'] .hero-content-wrapper { align-items: flex-end; }

  @media (min-width: 768px) {
    .hero-content-wrapper { padding-inline: 2rem; }
  }

  .hero-slide-text {
    pointer-events: auto;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .hero-content-layer[data-h='center'] .hero-slide-text { align-items: center; }
  .hero-content-layer[data-h='right'] .hero-slide-text { align-items: flex-end; }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 1.5rem;
    max-width: 820px;
  }

  .hero-content-layer[data-h='left'] .hero-content { align-items: flex-start; text-align: left; }
  .hero-content-layer[data-h='center'] .hero-content { align-items: center; text-align: center; }
  .hero-content-layer[data-h='right'] .hero-content { align-items: flex-end; text-align: right; }

  /* ─── Cascada de estilos por bloque (CIBA-2593) ───
     bloque por vista (--hero-block-*-desktop/-mobile, inline en .hero-slide-text)
     > slide.typography (--hero-*) > default del tema. Las vars de bloque sólo
     existen cuando el CMS define el override, así el fallback de var() reproduce
     exactamente la cascada actual. "mobile" = max-width 767px, el MISMO
     breakpoint que la variante portrait 9:16 (PORTRAIT_MEDIA_QUERY, CIBA-2558).
     `subtitle_color` colorea subtitle y overline (contrato §2). */

  /* Overline en versalitas con tracking (accent configurable). */
  .hero-tag {
    display: inline-block;
    color: var(--hero-block-subtitle-color-desktop, var(--hero-title-accent, #fbbf24));
    font-family: var(--hero-subtitle-font, var(--font-body));
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
  }

  .hero-title {
    font-family: var(--hero-title-font, var(--font-heading));
    font-size: var(--hero-block-title-size-desktop, var(--hero-title-size, clamp(2.5rem, 7.5vw, 5.75rem)));
    font-weight: 700;
    line-height: 1.05;
    color: var(--hero-block-title-color-desktop, var(--hero-title-color, white));
    letter-spacing: -0.02em;
    max-width: 15ch;
    margin: 0;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
  }

  .hero-subtitle {
    font-family: var(--hero-subtitle-font, var(--font-body));
    font-size: var(--hero-block-subtitle-size-desktop, var(--hero-subtitle-size, clamp(1rem, 2vw, 1.25rem)));
    color: var(--hero-block-subtitle-color-desktop, var(--hero-subtitle-color, rgba(255, 255, 255, 0.8)));
    line-height: 1.6;
    max-width: 46ch;
    margin: 0;
  }

  @media (max-width: 767px) {
    .hero-tag {
      color: var(--hero-block-subtitle-color-mobile, var(--hero-title-accent, #fbbf24));
    }
    .hero-title {
      font-size: var(--hero-block-title-size-mobile, var(--hero-title-size, clamp(2.5rem, 7.5vw, 5.75rem)));
      color: var(--hero-block-title-color-mobile, var(--hero-title-color, white));
    }
    .hero-subtitle {
      font-size: var(--hero-block-subtitle-size-mobile, var(--hero-subtitle-size, clamp(1rem, 2vw, 1.25rem)));
      color: var(--hero-block-subtitle-color-mobile, var(--hero-subtitle-color, rgba(255, 255, 255, 0.8)));
    }
  }

  /* ─── Toggles de CTA por vista (CIBA-2593) ───
     Salvaguarda SSR/pre-hidratación: display:none saca el CTA del tab-order y
     del árbol de accesibilidad; tras hidratar, el nodo se elimina del DOM. */
  @media (min-width: 768px) {
    .hero-cta--hide-desktop {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .hero-cta--hide-mobile {
      display: none;
    }
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: flex-start;
    margin-top: 0.5rem;
  }

  .hero-content-layer[data-h='left'] .hero-actions { justify-content: flex-start; }
  .hero-content-layer[data-h='center'] .hero-actions { justify-content: center; }
  .hero-content-layer[data-h='right'] .hero-actions { justify-content: flex-end; }

  .btn-reserve {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: var(--hero-btn-bg, #f59e0b);
    color: var(--hero-btn-text-color, white);
    font-family: var(--hero-btn-font, var(--font-body));
    font-weight: 600;
    font-size: var(--hero-btn-size, 1rem);
    border-radius: 9999px;
    text-decoration: none;
    transition: transform 150ms ease, box-shadow 200ms ease, filter 200ms ease;
    min-height: 48px;
  }

  .btn-reserve:hover {
    transform: translateY(-2px);
    filter: brightness(0.94);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.28);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.75rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: white;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 9999px;
    text-decoration: none;
    backdrop-filter: blur(8px);
    transition: background 200ms ease, border-color 200ms ease;
    min-height: 48px;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.4);
  }

  /* ─── Control de sonido (patrón lake-950 α0.72) ─── */
  .hero-sound {
    position: absolute;
    top: max(1.25rem, env(safe-area-inset-top));
    right: max(1.25rem, env(safe-area-inset-right));
    z-index: 20;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 48px;
    min-width: 48px;
    padding: 0 0.875rem;
    background: rgba(8, 47, 73, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 9999px;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: background 200ms ease, border-color 200ms ease, transform 150ms ease;
  }

  .hero-sound[hidden] { display: none; }

  .hero-sound:hover {
    background: rgba(8, 47, 73, 0.9);
    border-color: rgba(255, 255, 255, 0.6);
    transform: translateY(-1px);
  }

  .hero-sound:focus-visible {
    outline: 3px solid var(--color-sun-400, #fbbf24);
    outline-offset: 2px;
  }

  .hero-sound-icon { flex-shrink: 0; }
  .hero-sound-icon--on { display: none; }
  .hero-sound[aria-pressed='true'] .hero-sound-icon--muted { display: none; }
  .hero-sound[aria-pressed='true'] .hero-sound-icon--on { display: inline; }
  .hero-sound-label { white-space: nowrap; }

  .hero-sound[aria-pressed='false'] {
    animation: soundPulse 2.4s ease-in-out infinite;
  }

  @keyframes soundPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0); }
    50% { box-shadow: 0 0 0 6px rgba(245, 158, 11, 0.18); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-sound[aria-pressed='false'] { animation: none; }
  }

  @media (max-width: 480px) {
    .hero-sound { padding: 0; width: 48px; justify-content: center; }
    .hero-sound-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }

  /* ─── Indicadores (dots) — spec §2 ─── */
  .hero-dots {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: max(1.75rem, env(safe-area-inset-bottom));
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: rgba(8, 47, 73, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 9999px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .hero-dot {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: 0;
    margin: 0;
    padding: 8px; /* hit-area ≥ 24×24 (8px shape + 16px padding) */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius: 9999px;
  }

  .hero-dot-shape {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.45);
    transition: width 300ms cubic-bezier(0.4, 0, 0.2, 1), background-color 300ms ease;
  }

  .hero-dot:hover .hero-dot-shape { background: rgba(255, 255, 255, 0.75); }

  .hero-dot[data-active='true'] .hero-dot-shape {
    width: 24px;
    background: #f59e0b; /* sun-500 */
  }

  .hero-dot:focus-visible {
    outline: 3px solid var(--color-sun-400, #fbbf24);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-dot-shape { transition: none; }
  }

  /* ─── Flechas prev/next — spec §3 (default OFF, sólo ≥1024px) ─── */
  .hero-arrow { display: none; }

  @media (min-width: 1024px) {
    .hero-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 20;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      border-radius: 9999px;
      background: rgba(8, 47, 73, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.22);
      color: #ffffff;
      cursor: pointer;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      transition: background 200ms ease, transform 150ms ease;
    }
    .hero-arrow--prev { left: max(1rem, env(safe-area-inset-left)); }
    .hero-arrow--next { right: max(1rem, env(safe-area-inset-right)); }
    .hero-arrow:hover { background: rgba(8, 47, 73, 0.9); }
    .hero-arrow--prev:hover { transform: translateY(-50%) translateX(-2px); }
    .hero-arrow--next:hover { transform: translateY(-50%) translateX(2px); }
    .hero-arrow:focus-visible { outline: 3px solid #fbbf24; outline-offset: 2px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-arrow--prev:hover,
    .hero-arrow--next:hover { transform: translateY(-50%); }
  }

  /* ─── Scroll indicator (single-slide) ─── */
  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,0.5));
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-line { animation: none; opacity: 0.5; }
  }
</style>
