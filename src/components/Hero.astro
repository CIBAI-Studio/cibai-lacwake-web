---
import HeroAnimated from './react/HeroAnimated';

interface Props {
  title?: string;
  subtitle?: string;
  videoSrc?: string;
  fallbackImage?: string;
  ctaUrl?: string;
  ctaLabel?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryUrl?: string;
}

const {
  title = 'Tu aventura empieza en el agua',
  subtitle = 'Kayak, wake, esquí náutico y paseos en el embalse de la Baells. El pantano te espera.',
  videoSrc = '/assets/redesign/hero-baells.mp4',
  fallbackImage = '/assets/redesign/wakeboard.webp',
  ctaUrl,
  ctaLabel,
  ctaSecondaryLabel,
  ctaSecondaryUrl,
} = Astro.props;
---

<section class="hero" aria-label="Imagen principal">
  <!-- Background video -->
  <div class="hero-media" aria-hidden="true">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      poster={fallbackImage}
      preload="none"
    >
      <source src={videoSrc} type="video/mp4" />
    </video>
    <!-- Fallback visible si no hay vídeo -->
    <img
      class="hero-fallback"
      src={fallbackImage}
      alt=""
      aria-hidden="true"
      width="1920"
      height="1080"
      loading="eager"
    />
    <!-- Overlay -->
    <div class="hero-overlay" aria-hidden="true"></div>
  </div>

  <!-- Animated content (React) -->
  <div class="hero-content-wrapper">
    <HeroAnimated
      client:load
      title={title}
      subtitle={subtitle}
      reserveUrl={ctaUrl}
      reserveLabel={ctaLabel}
      reserveSecondaryLabel={ctaSecondaryLabel}
      reserveSecondaryUrl={ctaSecondaryUrl}
    />
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #082f49;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    /* Ocultar imagen si el vídeo se carga correctamente */
  }

  /* Solo ocultar fallback si el vídeo no tiene poster definido */
  .hero-video:not([poster]) ~ .hero-fallback {
    display: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.28) 45%,
      rgba(0, 0, 0, 0.65) 100%
    );
  }

  .hero-content-wrapper {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 900px;
    padding-inline: 1.25rem;
    padding-block: 6rem 4rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .hero-content-wrapper {
      padding-inline: 2rem;
    }
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,0.5));
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-line {
      animation: none;
      opacity: 0.5;
    }
  }
</style>

<style is:global>
  /* Estilos del componente React HeroAnimated */
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-tag {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    background: rgba(245, 158, 11, 0.25);
    border: 1px solid rgba(245, 158, 11, 0.4);
    color: #fbbf24;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 9999px;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 7.5vw, 5.75rem);
    font-weight: 700;
    line-height: 1.02;
    color: white;
    letter-spacing: -0.035em;
    max-width: 780px;
    margin: 0;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    max-width: 520px;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .btn-reserve {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: #f59e0b;
    color: white;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: background 200ms ease, transform 150ms ease;
    min-height: 48px;
  }

  .btn-reserve:hover {
    background: #d97706;
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.75rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: white;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 9999px;
    text-decoration: none;
    backdrop-filter: blur(8px);
    transition: background 200ms ease, border-color 200ms ease;
    min-height: 48px;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.4);
  }
</style>

<script>
  const video = document.querySelector<HTMLVideoElement>('.hero-video');
  const fallback = document.querySelector<HTMLElement>('.hero-fallback');
  if (video && fallback) {
    video.addEventListener('canplay', () => {
      fallback.style.display = 'none';
    });
  }
</script>
