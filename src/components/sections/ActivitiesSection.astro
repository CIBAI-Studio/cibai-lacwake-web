---
import ActivityTile from '../ActivityTile.astro';
import { ACTIVITY_FAMILIES, ACTIVITY_COUNT } from '../../config/actividades';

interface Props {
  whatsappUrl: string;
}

const { whatsappUrl } = Astro.props;
---

<section class="activities" id="actividades" aria-labelledby="activities-title">
  <!-- Decoración botánica -->
  <img
    src="/assets/redesign/decor/leaf-sprig.svg"
    alt=""
    aria-hidden="true"
    class="decor decor--top-right"
    width="180"
    height="180"
  />

  <div class="container-site">

    <!-- Cabecera de sección -->
    <header class="activities-head">
      <div class="activities-overline">Catálogo completo</div>
      <h2 class="activities-title" id="activities-title">
        {ACTIVITY_COUNT} formas de vivir el agua
      </h2>
      <p class="activities-lead">
        Del kayak tranquilo al wakeboard más intenso. Elige tu plan en el embalse
        de la Baells y reserva por WhatsApp en un clic.
      </p>
    </header>

    <!-- Familias de actividad -->
    {ACTIVITY_FAMILIES.map((family) => (
      <div class="family" aria-labelledby={`family-${family.id}`}>

        <div class="family-head">
          <span class="family-index" aria-hidden="true">{family.index}</span>
          <div class="family-heading">
            <div class="family-label">{family.label}</div>
            <h3 class="family-title" id={`family-${family.id}`}>{family.title}</h3>
            <p class="family-desc">{family.description}</p>
          </div>
        </div>

        <ul
          class:list={['family-grid', `family-grid--${family.activities.length}`]}
          role="list"
        >
          {family.activities.map((activity, i) => (
            <li>
              <ActivityTile
                activity={activity}
                whatsappUrl={whatsappUrl}
                featured={family.activities.length === 3 && i === 0}
              />
            </li>
          ))}
        </ul>

      </div>
    ))}

  </div>

  <!-- Divider decorativo inferior -->
  <div class="wave-divider" aria-hidden="true">
    <img
      src="/assets/redesign/decor/wave-divider.svg"
      alt=""
      width="1440"
      height="48"
    />
  </div>
</section>

<style>
  /* ── Shell ─────────────────────────────────────────────────── */
  .activities {
    position: relative;
    padding-block: 5rem;
    background: #ffffff;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .activities {
      padding-block: 7rem 6rem;
    }
  }

  /* ── Decoración ──────────────────────────────────────────── */
  .decor {
    position: absolute;
    pointer-events: none;
    opacity: 0.28;
    user-select: none;
  }

  .decor--top-right {
    top: -1rem;
    right: -2rem;
    width: 160px;
    transform: rotate(15deg);
  }

  @media (min-width: 1024px) {
    .decor--top-right {
      width: 220px;
      right: 2rem;
    }
  }

  /* ── Cabecera ──────────────────────────────────────────────── */
  .activities-head {
    max-width: 640px;
    margin-bottom: 4rem;
  }

  .activities-overline {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #92400e;
    margin-bottom: 0.875rem;
  }

  .activities-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5.5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #1c1917;
    margin: 0 0 1rem;
  }

  .activities-lead {
    font-size: 1.075rem;
    line-height: 1.65;
    color: #78716c;
    margin: 0;
  }

  /* ── Familia ───────────────────────────────────────────────── */
  .family {
    margin-top: 4rem;
    padding-top: 3.5rem;
    border-top: 1px solid #e7e5e4;
  }

  .family:first-of-type {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  .family-head {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  /* Número grande outlined en amber */
  .family-index {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.05em;
    color: transparent;
    -webkit-text-stroke: 1.5px #f59e0b;
    flex-shrink: 0;
    margin-top: 0.25rem;
    opacity: 0.7;
  }

  .family-heading {
    flex: 1;
  }

  .family-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #92400e;
    margin-bottom: 0.4rem;
  }

  .family-title {
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 3vw, 2rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: #1c1917;
    margin: 0 0 0.6rem;
  }

  .family-desc {
    font-size: 1rem;
    line-height: 1.65;
    color: #78716c;
    margin: 0;
    max-width: 600px;
  }

  /* ── Grid de cards ─────────────────────────────────────────── */
  .family-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.375rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .family-grid > li {
    display: flex;
  }

  @media (min-width: 600px) {
    .family-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    /* 3 actividades: primera destacada (span 2) + 2 en columna derecha */
    .family-grid--3 {
      grid-template-columns: repeat(3, 1fr);
    }
    .family-grid--3 > li:first-child {
      grid-column: span 2;
    }

    /* 4 actividades: cuadrícula 2×2 limpia */
    .family-grid--4 {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 1024px) and (max-width: 1279px) {
    .family-grid--4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Wave divider ──────────────────────────────────────────── */
  .wave-divider {
    margin-top: 3rem;
    line-height: 0;
    opacity: 0.35;
  }

  .wave-divider img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
