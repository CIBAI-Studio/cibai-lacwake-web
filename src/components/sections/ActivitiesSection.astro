---
import ActivityTile from '../ActivityTile.astro';
import { ACTIVITY_FAMILIES, type Activity } from '../../config/actividades';
import { getHomeContent, type HomeActivity } from '../../lib/cms';
// Line-art recoloreable (currentColor) → inline para heredar el teal (punto 4)
import montanasSolPuente from '../../../public/assets/redesign/decor/montanas-sol-puente.svg?raw';

interface Props {
  whatsappUrl: string;
}

const { whatsappUrl } = Astro.props;

// ── Fuente única: admin «Home (tarjetas)» (CIBA-2538) ────────────────────────
// La key `home.activities` del CMS es la lista AUTORITATIVA: se pinta exactamente
// lo que hay en admin — ni catálogo mergeado ni tarjetas autogeneradas desde el
// índice de actividades (origen de las 3 Kayak fantasma en «Navega sin prisa»).
// Sólo si el CMS está caído o la key no existe (`home === null`) se cae al
// catálogo semilla completo para no dejar la sección en blanco.
const home = await getHomeContent();

const pick = (o: string | undefined, fb: string): string =>
  o !== undefined && o.trim() !== '' ? o : fb;

// Semilla por slug: arte y copy de respaldo para cards del admin con campos vacíos.
const seedBySlug = new Map(
  ACTIVITY_FAMILIES.flatMap((f) => f.activities.map((a) => [a.slug, a] as const)),
);

/** Card del admin → modelo de render, con la semilla como fallback por campo. */
function toActivity(card: HomeActivity): Activity {
  const seed = seedBySlug.get(card.id);
  return {
    slug: card.id,
    name: pick(card.title, seed?.name ?? card.id),
    blurb: pick(card.blurb, seed?.blurb ?? ''),
    tag: pick(card.tag, seed?.tag ?? ''),
    image: pick(card.image, seed?.image ?? '/assets/images/hero-fallback.jpg'),
    imageAlt: pick(
      card.imageAlt,
      seed?.imageAlt ?? `${pick(card.title, card.id)} en el pantano de la Baells`,
    ),
    href: pick(card.pageHref, seed?.href ?? `/actividades/${card.id}`),
  };
}

// `family` en admin es texto libre; ids válidos = los del catálogo (kayak, wake,
// paseos). `tranquilo` es alias legado (contrato CIBA-2519); cualquier otro valor
// cae en `paseos` para que una card creada en admin nunca desaparezca en silencio.
const FAMILY_IDS = new Set(ACTIVITY_FAMILIES.map((f) => f.id));
const familyOf = (card: HomeActivity): string => {
  const f = (card.family ?? '').trim().toLowerCase();
  if (FAMILY_IDS.has(f)) return f;
  return 'paseos';
};

interface CardVM {
  activity: Activity;
  ctaLabel?: string;
  ctaMessage?: string;
}

const families = ACTIVITY_FAMILIES.map((family) => {
  const cards: CardVM[] =
    home !== null
      ? home.activities
          .filter((c) => familyOf(c) === family.id)
          .map((c) => ({
            activity: toActivity(c),
            ctaLabel: c.ctaLabel,
            ctaMessage: c.ctaWhatsappMessage,
          }))
      : family.activities.map((a) => ({ activity: a }));

  return { ...family, cards };
}).filter((family) => family.cards.length > 0);

const totalActivities = families.reduce((n, f) => n + f.cards.length, 0);
---

{totalActivities > 0 && (
<section class="activities" id="actividades" aria-labelledby="activities-title">
  <!-- Line-art montañas + sol + puente Baells, esquina sup-derecha (punto 4).
       Inline + currentColor teal + opacidad baja como lavado de fondo. -->
  <div class="decor decor--mountains" aria-hidden="true" set:html={montanasSolPuente} />

  <!-- Rama botánica teal, margen izquierdo a lo largo de la sección (punto 3) -->
  <img
    src="/assets/redesign/decor/botanica-teal.png"
    alt=""
    aria-hidden="true"
    class="decor decor--left"
    width="360"
    height="620"
    loading="lazy"
    decoding="async"
  />
  <!-- Rama olivo+bayas, margen derecho (punto 3) -->
  <img
    src="/assets/redesign/decor/botanica-margen.png"
    alt=""
    aria-hidden="true"
    class="decor decor--right"
    width="360"
    height="620"
    loading="lazy"
    decoding="async"
  />

  <div class="container-site">

    <!-- Cabecera de sección -->
    <header class="activities-head">
      <div class="activities-overline">Catálogo completo</div>
      <h2 class="activities-title" id="activities-title">
        {totalActivities} formas de vivir el agua
      </h2>
      <p class="activities-lead">
        Del kayak tranquilo al wakeboard más intenso. Elige tu plan en el embalse
        de la Baells y reserva por WhatsApp en un clic.
      </p>
    </header>

    <!-- Familias de actividad -->
    {families.map((family) => (
      <div class="family" aria-labelledby={`family-${family.id}`}>

        <div class="family-head">
          <span class="family-index" aria-hidden="true">{family.index}</span>
          <div class="family-heading">
            <div class="family-label">{family.label}</div>
            <h3 class="family-title" id={`family-${family.id}`}>{family.title}</h3>
            <p class="family-desc">{family.description}</p>
          </div>
        </div>

        <ul
          class:list={['family-grid', `family-grid--${family.cards.length}`]}
          role="list"
        >
          {family.cards.map((card, i) => (
            <li>
              <ActivityTile
                activity={card.activity}
                whatsappUrl={whatsappUrl}
                featured={family.cards.length === 3 && i === 0}
                ctaLabel={card.ctaLabel}
                ctaMessage={card.ctaMessage}
              />
            </li>
          ))}
        </ul>

      </div>
    ))}

  </div>

  <!-- Divider decorativo inferior -->
  <div class="wave-divider" aria-hidden="true">
    <img
      src="/assets/redesign/decor/wave-divider.svg"
      alt=""
      width="1440"
      height="48"
    />
  </div>
</section>
)}

<style>
  /* ── Shell ─────────────────────────────────────────────────── */
  .activities {
    position: relative;
    padding-block: 5rem;
    /* Fondo claro tipo papel/acuarela (punto 4) */
    background:
      radial-gradient(60% 40% at 88% 6%, #eaf3f1 0%, rgba(234, 243, 241, 0) 60%),
      #fdfcfa;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .activities {
      padding-block: 7rem 6rem;
    }
  }

  /* ── Decoración ──────────────────────────────────────────── */
  .decor {
    position: absolute;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  /* Line-art montañas+sol+puente (inline SVG, recoloreado a teal) */
  .decor--mountains {
    top: -0.5rem;
    right: -1rem;
    width: 300px;
    max-width: 55vw;
    color: var(--color-teal-ink); /* currentColor del line-art */
    opacity: 0.55;
  }
  .decor--mountains :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Ramas botánicas nítidas en los márgenes (raster) */
  .decor--left,
  .decor--right {
    top: 34%;
    width: 150px;
    max-width: 28vw;
    opacity: 0.8;
  }
  .decor--left { left: -5rem; }
  .decor--right { right: -5rem; bottom: 8%; top: auto; transform: scaleX(-1); }

  @media (min-width: 1024px) {
    .decor--mountains {
      width: 420px;
      right: 1.5rem;
    }
    .decor--left { width: 210px; left: -3.5rem; }
    .decor--right { width: 220px; right: -3.5rem; }
  }

  @media (max-width: 767px) {
    .decor--left,
    .decor--right { display: none; }
  }

  /* El contenido va por encima de los decorativos */
  .activities > .container-site {
    position: relative;
    z-index: 1;
  }

  /* ── Cabecera ──────────────────────────────────────────────── */
  .activities-head {
    max-width: 640px;
    margin-bottom: 4rem;
  }

  .activities-overline {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-teal-ink); /* AA 5.12 sobre papel claro */
    margin-bottom: 0.875rem;
  }

  .activities-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5.5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #1c1917;
    margin: 0 0 1rem;
  }

  .activities-lead {
    font-size: 1.075rem;
    line-height: 1.65;
    color: #78716c;
    margin: 0;
  }

  /* ── Familia ───────────────────────────────────────────────── */
  .family {
    margin-top: 4rem;
    padding-top: 3.5rem;
    border-top: 1px solid #e7e5e4;
  }

  .family:first-of-type {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  .family-head {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  /* Número grande outlined en amber */
  .family-index {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.05em;
    color: transparent;
    -webkit-text-stroke: 1.5px var(--color-teal-pastel); /* tono frío pastel (punto 7) */
    flex-shrink: 0;
    margin-top: 0.25rem;
    opacity: 0.85;
  }

  .family-heading {
    flex: 1;
  }

  .family-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-teal-ink); /* AA 5.12 */
    margin-bottom: 0.4rem;
  }

  .family-title {
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 3vw, 2rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: #1c1917;
    margin: 0 0 0.6rem;
  }

  .family-desc {
    font-size: 1rem;
    line-height: 1.65;
    color: #78716c;
    margin: 0;
    max-width: 600px;
  }

  /* ── Grid de cards ─────────────────────────────────────────── */
  .family-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.375rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .family-grid > li {
    display: flex;
  }

  @media (min-width: 600px) {
    .family-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    /* 3 actividades: primera destacada (span 2) + 2 en columna derecha */
    .family-grid--3 {
      grid-template-columns: repeat(3, 1fr);
    }
    .family-grid--3 > li:first-child {
      grid-column: span 2;
    }

    /* 4 actividades: cuadrícula 2×2 limpia */
    .family-grid--4 {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 1024px) and (max-width: 1279px) {
    .family-grid--4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Wave divider ──────────────────────────────────────────── */
  .wave-divider {
    margin-top: 3rem;
    line-height: 0;
    opacity: 0.35;
  }

  .wave-divider img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
