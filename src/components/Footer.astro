---
import { getFooterContent, getSiteConfig } from '../lib/cms';

const siteConfig = await getSiteConfig();
const footer = await getFooterContent();

// `{year}` del CMS → año actual (CIBA-2402).
const copyrightText = footer.copyright.replaceAll('{year}', String(new Date().getFullYear()));
---

<footer class="site-footer" role="contentinfo">
  <!-- Textura de agua acuarela a todo ancho en el borde superior (punto 6) -->
  <img
    src="/assets/redesign/decor/agua-lateral.png"
    alt=""
    aria-hidden="true"
    class="footer-water"
    width="1440"
    height="360"
    loading="lazy"
    decoding="async"
  />

  <!-- Ilustración aves decorativa -->
  <img
    src="/assets/redesign/decor/birds-flock.svg"
    alt=""
    aria-hidden="true"
    class="footer-birds"
    width="200"
    height="80"
  />

  <div class="container-site">
    <div class="footer-grid">

      <!-- Brand -->
      <div class="footer-brand">
        <a href={footer.logoHref} class="footer-logo" aria-label={`${footer.logoText} — Inicio`}>
          {footer.logoImage ? (
            <img
              src={footer.logoImage}
              alt={footer.logoText}
              class="footer-logo-img"
              height="48"
              loading="lazy"
              decoding="async"
            />
          ) : (
            footer.logoText
          )}
        </a>
        <p class="footer-tagline">{footer.tagline}</p>
        <a
          href={siteConfig.whatsappUrl}
          class="footer-cta"
          target="_blank"
          rel="noopener noreferrer"
        >
          {siteConfig.whatsappLabel}
        </a>
      </div>

      <!-- Actividades -->
      <nav class="footer-col" aria-label="Actividades">
        <h3 class="footer-col-title">Actividades</h3>
        <ul role="list">
          {footer.navActividades.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Contacto -->
      <div class="footer-col">
        <h3 class="footer-col-title">Contacto</h3>
        <ul role="list">
          <li>
            <a href={siteConfig.phoneUrl} aria-label={`Llamar al ${siteConfig.phone}`}>
              {siteConfig.phone}
            </a>
          </li>
          <li>
            <a href={siteConfig.emailUrl}>{siteConfig.email}</a>
          </li>
          <li>
            <span class="footer-detail">{siteConfig.address}</span>
          </li>
          <li>
            <span class="footer-detail">{siteConfig.schedule}</span>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <nav class="footer-col" aria-label="Legal">
        <h3 class="footer-col-title">Legal</h3>
        <ul role="list">
          {footer.navLegal.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p>{copyrightText}</p>
      <p class="footer-bottom-links">
        <a href="/politica-privacidad">Privacidad</a>
        <span aria-hidden="true">·</span>
        <a href="/politica-cookies">Cookies</a>
        <span aria-hidden="true">·</span>
        <a href="/aviso-legal">Aviso legal</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background: var(--color-cream); /* footer claro (punto 6) */
    color: #1e293b; /* AA 13.69 sobre cream */
    padding-block: 4.5rem 2.5rem;
    margin-top: auto;
    overflow: hidden;
    border-top: 1px solid #ece6dc;
  }

  /* ── Textura de agua superior (punto 6) ───────────────────── */
  .footer-water {
    position: absolute;
    top: -3rem;
    left: 0;
    right: 0;
    width: 100%;
    height: auto;
    opacity: 0.45;
    pointer-events: none;
    user-select: none;
    mix-blend-mode: multiply;
  }

  /* ── Aves decorativas ─────────────────────────────────────── */
  .footer-birds {
    position: absolute;
    top: 2.5rem;
    right: 3rem;
    width: 160px;
    opacity: 0.3;
    pointer-events: none;
    user-select: none;
  }

  @media (max-width: 767px) {
    .footer-birds {
      display: none;
    }
  }

  /* Contenido por encima de la textura de agua decorativa */
  .site-footer .container-site {
    position: relative;
    z-index: 1;
  }

  /* ── Grid principal ───────────────────────────────────────── */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-bottom: 3.5rem;
  }

  @media (min-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  /* ── Brand ────────────────────────────────────────────────── */
  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.625rem;
    font-weight: 700;
    color: #0d9488; /* logo Lacwake turquesa (grande) */
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
    transition: color 150ms ease;
  }

  .footer-logo:hover {
    color: var(--color-teal-ink);
  }

  .footer-logo-img {
    display: block;
    height: 48px;
    width: auto;
  }

  .footer-tagline {
    font-size: 0.9375rem;
    line-height: 1.65;
    margin-bottom: 1.5rem;
    color: #475569; /* slate-600 sobre cream → AA 7+ */
    white-space: pre-line; /* preserva los `\n` del tagline CMS */
  }

  .footer-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.25rem;
    background: var(--color-sun-pastel); /* naranja pastel (punto 7) */
    color: #1e293b;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 9999px;
    text-decoration: none;
    min-height: 44px;
    transition: background 180ms ease;
  }

  .footer-cta:hover {
    background: var(--color-sun-pastel-hover);
  }

  /* ── Columnas ─────────────────────────────────────────────── */
  .footer-col-title {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-teal-ink); /* títulos teal AA 5.12 */
    margin-bottom: 1.1rem;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col a {
    color: var(--color-teal-ink); /* enlaces teal AA 5.12 */
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 150ms ease;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }

  .footer-col a:hover {
    color: #0d9488;
    text-decoration: underline;
  }

  .footer-detail {
    font-size: 0.9375rem;
    color: #1e293b; /* texto oscuro AA 13.69 */
    display: flex;
    align-items: center;
    min-height: 44px;
    line-height: 1.5;
  }

  /* ── Bottom bar ───────────────────────────────────────────── */
  .footer-bottom {
    border-top: 1px solid #e4ddd0;
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
    text-align: center;
    font-size: 0.875rem;
    color: #475569; /* slate-600 AA 7+ */
  }

  @media (min-width: 600px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer-bottom-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-bottom-links a {
    color: #475569;
    text-decoration: none;
    transition: color 150ms ease;
  }

  .footer-bottom-links a:hover {
    color: var(--color-teal-ink);
    text-decoration: underline;
  }
</style>
