---
import { getSiteConfig } from '../lib/cms';

const siteConfig = await getSiteConfig();
---

<footer class="site-footer" role="contentinfo">
  <!-- Ola decorativa en el borde superior -->
  <div class="footer-wave" aria-hidden="true">
    <img
      src="/assets/redesign/decor/wave-divider.svg"
      alt=""
      width="1440"
      height="60"
    />
  </div>

  <!-- Ilustración aves decorativa -->
  <img
    src="/assets/redesign/decor/birds-flock.svg"
    alt=""
    aria-hidden="true"
    class="footer-birds"
    width="200"
    height="80"
  />

  <div class="container-site">
    <div class="footer-grid">

      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Lacwake — Inicio">
          Lacwake
        </a>
        <p class="footer-tagline">
          Actividades acuáticas en el embalse de la Baells.<br />
          Kayak, wakeboard, paddle surf y más para toda la familia.
        </p>
        <a
          href={siteConfig.whatsappUrl}
          class="footer-cta"
          target="_blank"
          rel="noopener noreferrer"
        >
          {siteConfig.whatsappLabel}
        </a>
      </div>

      <!-- Actividades -->
      <nav class="footer-col" aria-label="Actividades">
        <h3 class="footer-col-title">Actividades</h3>
        <ul role="list">
          <li><a href="/actividades/kayak">Kayak</a></li>
          <li><a href="/actividades/hidropedales">Hidropedales</a></li>
          <li><a href="/actividades/barcas">Barcas</a></li>
          <li><a href="https://reservas.lacwake.es" target="_blank" rel="noopener noreferrer">Wakeboard &amp; Esquí</a></li>
          <li><a href="/actividades/sup">Paddle Surf</a></li>
        </ul>
      </nav>

      <!-- Contacto -->
      <div class="footer-col">
        <h3 class="footer-col-title">Contacto</h3>
        <ul role="list">
          <li>
            <a href={siteConfig.phoneUrl} aria-label={`Llamar al ${siteConfig.phone}`}>
              {siteConfig.phone}
            </a>
          </li>
          <li>
            <a href={siteConfig.emailUrl}>{siteConfig.email}</a>
          </li>
          <li>
            <span class="footer-detail">{siteConfig.address}</span>
          </li>
          <li>
            <span class="footer-detail">{siteConfig.schedule}</span>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <nav class="footer-col" aria-label="Legal">
        <h3 class="footer-col-title">Legal</h3>
        <ul role="list">
          <li><a href="/aviso-legal">Aviso legal</a></li>
          <li><a href="/politica-privacidad">Política de privacidad</a></li>
          <li><a href="/politica-cookies">Política de cookies</a></li>
          <li><a href="/condiciones-contratacion">Condiciones</a></li>
        </ul>
      </nav>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Lacwake · Berguedà Nàutic SL</p>
      <p class="footer-bottom-links">
        <a href="/politica-privacidad">Privacidad</a>
        <span aria-hidden="true">·</span>
        <a href="/politica-cookies">Cookies</a>
        <span aria-hidden="true">·</span>
        <a href="/aviso-legal">Aviso legal</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background: #082f49;
    color: rgba(255, 255, 255, 0.65);
    padding-block: 4.5rem 2.5rem;
    margin-top: auto;
    overflow: hidden;
  }

  /* ── Ola superior ─────────────────────────────────────────── */
  .footer-wave {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    line-height: 0;
    opacity: 0.25;
    transform: rotate(180deg);
    pointer-events: none;
  }

  .footer-wave img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Aves decorativas ─────────────────────────────────────── */
  .footer-birds {
    position: absolute;
    top: 2.5rem;
    right: 3rem;
    width: 160px;
    opacity: 0.18;
    pointer-events: none;
    user-select: none;
  }

  @media (max-width: 767px) {
    .footer-birds {
      display: none;
    }
  }

  /* ── Grid principal ───────────────────────────────────────── */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-bottom: 3.5rem;
  }

  @media (min-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  /* ── Brand ────────────────────────────────────────────────── */
  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.625rem;
    font-weight: 700;
    color: white;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
    transition: color 150ms ease;
  }

  .footer-logo:hover {
    color: #f59e0b;
  }

  .footer-tagline {
    font-size: 0.9375rem;
    line-height: 1.65;
    margin-bottom: 1.5rem;
    color: rgba(255, 255, 255, 0.55);
  }

  .footer-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.25rem;
    background: #f59e0b;
    color: #1c1917;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 9999px;
    text-decoration: none;
    min-height: 44px;
    transition: background 180ms ease;
  }

  .footer-cta:hover {
    background: #d97706;
  }

  /* ── Columnas ─────────────────────────────────────────────── */
  .footer-col-title {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 1.1rem;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col a {
    color: rgba(255, 255, 255, 0.62);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 150ms ease;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }

  .footer-col a:hover {
    color: white;
  }

  .footer-detail {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.45);
    display: flex;
    align-items: center;
    min-height: 44px;
    line-height: 1.5;
  }

  /* ── Bottom bar ───────────────────────────────────────────── */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
    text-align: center;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.35);
  }

  @media (min-width: 600px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer-bottom-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-bottom-links a {
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .footer-bottom-links a:hover {
    color: rgba(255, 255, 255, 0.75);
  }
</style>
