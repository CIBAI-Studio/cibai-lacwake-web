---
import { getMenu, getSiteConfig } from '../lib/cms';

const [navLinks, siteConfig] = await Promise.all([getMenu(), getSiteConfig()]);
const currentPath = Astro.url.pathname;
---

<header class="site-header" role="banner" id="site-header">
  <div class="header-inner container-site">
    <!-- Logo -->
    <a href="/" class="header-logo" aria-label="Lacwake — Inicio">
      <span class="logo-text">Lacwake</span>
    </a>

    <!-- Desktop nav -->
    <nav class="header-nav" aria-label="Navegación principal">
      <ul class="nav-links" role="list">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="nav-link"
              aria-current={currentPath === href ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA desktop -->
    <a
      href={siteConfig.whatsappUrl}
      class="header-cta"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`${siteConfig.whatsappLabelShort} — abre en nueva pestaña`}
    >
      {siteConfig.whatsappLabelShort}
    </a>

    <!-- Mobile hamburger -->
    <button
      class="nav-hamburger"
      id="nav-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>

  <!-- Mobile menu (panel desplegable) -->
  <div
    class="mobile-panel"
    id="mobile-menu"
    aria-hidden="true"
    role="dialog"
    aria-label="Menú móvil"
  >
    <div class="container-site">
      <ul class="mobile-list" role="list">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="mobile-link"
              aria-current={currentPath === href ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
        <li>
          <a
            href={siteConfig.whatsappUrl}
            class="mobile-cta"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${siteConfig.whatsappLabel} — abre en nueva pestaña`}
          >
            {siteConfig.whatsappLabel}
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<style>
  /* ── Header shell ─────────────────────────────────────────────── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    transition:
      background 280ms ease,
      border-color 280ms ease,
      box-shadow 280ms ease;
    background: transparent;
    border-bottom: 1px solid transparent;
  }

  .site-header.scrolled {
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(14px) saturate(180%);
    -webkit-backdrop-filter: blur(14px) saturate(180%);
    border-bottom-color: rgba(231, 229, 228, 0.65);
    box-shadow: 0 1px 16px rgba(0, 0, 0, 0.055);
  }

  /* ── Inner layout ─────────────────────────────────────────────── */
  .header-inner {
    display: flex;
    align-items: center;
    height: 4rem;
    gap: 0.75rem;
  }

  /* ── Logo ─────────────────────────────────────────────────────── */
  .header-logo {
    text-decoration: none;
    flex-shrink: 0;
    margin-right: auto;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: white;
    transition: color 280ms ease;
  }

  .site-header.scrolled .logo-text {
    color: #1c1917;
  }

  /* ── Desktop nav ──────────────────────────────────────────────── */
  .header-nav {
    display: none;
  }

  @media (min-width: 768px) {
    .header-nav {
      display: block;
    }
  }

  .nav-links {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.125rem;
  }

  .nav-link {
    display: block;
    padding: 0.4rem 0.875rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.82);
    text-decoration: none;
    border-radius: 0.5rem;
    transition: color 180ms ease, background 180ms ease;
  }

  .site-header.scrolled .nav-link {
    color: #44403c;
  }

  .nav-link:hover,
  .nav-link[aria-current="page"] {
    color: white;
    background: rgba(255, 255, 255, 0.13);
  }

  .site-header.scrolled .nav-link:hover,
  .site-header.scrolled .nav-link[aria-current="page"] {
    color: #1c1917;
    background: rgba(0, 0, 0, 0.055);
  }

  /* ── CTA ──────────────────────────────────────────────────────── */
  .header-cta {
    display: none;
    flex-shrink: 0;
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #1c1917;
    background: #f59e0b;
    border-radius: 9999px;
    text-decoration: none;
    min-height: 44px;
    align-items: center;
    white-space: nowrap;
    transition: background 180ms ease, transform 140ms ease;
  }

  @media (min-width: 768px) {
    .header-cta {
      display: flex;
    }
  }

  .header-cta:hover {
    background: #d97706;
    transform: translateY(-1px);
  }

  .header-cta:active {
    transform: translateY(0);
  }

  /* ── Hamburger ────────────────────────────────────────────────── */
  .nav-hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 0.625rem;
    background: transparent;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    margin-left: auto;
  }

  @media (min-width: 768px) {
    .nav-hamburger {
      display: none;
    }
  }

  .hamburger-line {
    display: block;
    height: 1.5px;
    background: white;
    border-radius: 2px;
    transition: transform 260ms ease, opacity 260ms ease, background 280ms ease;
  }

  .site-header.scrolled .hamburger-line {
    background: #292524;
  }

  .nav-hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ── Mobile panel ─────────────────────────────────────────────── */
  .mobile-panel {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    visibility: hidden;
    transition:
      max-height 320ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 280ms ease,
      visibility 280ms ease;
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(231, 229, 228, 0.6);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .mobile-panel[aria-hidden="false"] {
    max-height: 340px;
    opacity: 1;
    visibility: visible;
  }

  .mobile-list {
    list-style: none;
    margin: 0;
    padding: 0.625rem 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .mobile-link {
    display: flex;
    align-items: center;
    padding: 0.75rem 0;
    font-size: 1rem;
    font-weight: 500;
    color: #292524;
    text-decoration: none;
    min-height: 44px;
    transition: color 150ms ease;
  }

  .mobile-link:hover,
  .mobile-link[aria-current="page"] {
    color: #d97706;
  }

  .mobile-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.625rem;
    padding: 0.875rem 1rem;
    font-size: 1rem;
    font-weight: 600;
    color: #1c1917;
    background: #f59e0b;
    border-radius: 0.875rem;
    text-decoration: none;
    min-height: 48px;
    transition: background 150ms ease;
  }

  .mobile-cta:hover {
    background: #d97706;
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  function handleScroll() {
    if (!header) return;
    header.classList.toggle('scrolled', window.scrollY > 60);
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(isOpen));
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      toggle.setAttribute('aria-expanded', 'false');
      mobileMenu?.setAttribute('aria-hidden', 'true');
      toggle.focus();
    }
  });
</script>
