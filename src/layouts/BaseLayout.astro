---
import '../styles/global.css';
import NavIsland from '../components/NavIsland.astro';
import Footer from '../components/Footer.astro';
import { getSeo } from '../lib/cms';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  /** pageKey del contrato `site_seo` (CIBA-2561); sin él, no hay overrides de admin. */
  seoKey?: string;
}

const {
  title,
  description: fallbackDescription = 'Lacwake — Actividades acuáticas en el pantano. Kayak, hidropedales y barcas para toda la familia.',
  image = '/assets/images/og-default.jpg',
  noIndex = false,
  seoKey,
} = Astro.props;

const seo = seoKey ? await getSeo(seoKey) : {};

// Overrides campo a campo: cada meta cae al valor actual de la página si el
// admin no lo ha rellenado, de modo que sin overrides el head no cambia.
// `seo.title` del admin se usa tal cual (título completo, sin sufijo).
const fullTitle = seo.title ?? (title === 'Lacwake' ? title : `${title} | Lacwake`);
const description = seo.description ?? fallbackDescription;
// `new URL(x, base)` absolutiza rutas relativas y respeta URLs ya absolutas.
const canonicalURL = new URL(seo.canonical ?? Astro.url.pathname, Astro.site).href;
const ogTitle = seo.ogTitle ?? fullTitle;
const ogDescription = seo.ogDescription ?? description;
const ogImage = new URL(seo.ogImage ?? image, Astro.site).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {seo.keywords && <meta name="keywords" content={seo.keywords} />}
    <link rel="canonical" href={canonicalURL} />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Lacwake" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Fuentes self-hosted (CIBA-2201): preload de las variantes base del sitio.
         El Hero precarga además su fuente de título en su propio render. -->
    <link
      rel="preload"
      href="/assets/fonts/spacegrotesk-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/assets/fonts/inter-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <NavIsland />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
