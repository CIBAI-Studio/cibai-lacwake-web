---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
  /** pageKey del contrato `site_seo` (CIBA-2561): aviso_legal, privacidad, cookies, condiciones. */
  seoKey?: string;
}

const { title, description, lastUpdated, seoKey } = Astro.props;
---

<BaseLayout title={title} description={description} seoKey={seoKey} noIndex>
  <div class="container-site section" style="padding-top: 7rem;">
    <div class="prose mx-auto">
      <h1 style="font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: 0.5rem;">{title}</h1>
      {lastUpdated && (
        <p style="font-size: 0.875rem; color: #a8a29e; margin-bottom: 2rem;">
          Última actualización: {lastUpdated}
        </p>
      )}
      <slot />
    </div>
  </div>
</BaseLayout>
